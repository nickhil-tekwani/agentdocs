# Local server
HOST=127.0.0.1
PORT=4100
AGENTDOCS_DATA_DIR=./data
# Comma-separated absolute directories that may be opened. Empty means the current repository only.
AGENTDOCS_ALLOWED_REPOSITORY_ROOTS=
AGENTDOCS_GIT_AUTHOR_NAME=AgentDocs
AGENTDOCS_GIT_AUTHOR_EMAIL=agentdocs@example.invalid

# Optional GitHub App/OAuth integration values for the hosted adapter.
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Required before exposing a future hosted/multi-user deployment.
AGENTDOCS_SESSION_SECRET=
